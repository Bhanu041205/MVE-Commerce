# Frontend Environment Variables
# Copy this file to .env and update the values for your environment

# Backend API Configuration
# Local development
# VITE_API_URL=http://localhost:6969/api

# Production (Render)
VITE_API_URL=https://mandova-backend.onrender.com/api

# Google OAuth Configuration (Optional)
# VITE_GOOGLE_CLIENT_ID=your-google-client-id-here
# VITE_GOOGLE_REDIRECT_URI=https://your-frontend-url.onrender.com/auth/callback

# GitHub OAuth Configuration (Optional)
# VITE_GITHUB_CLIENT_ID=your-github-client-id-here
# VITE_GITHUB_REDIRECT_URI=https://your-frontend-url.onrender.com/auth/github-callback
